<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Integrated Implants</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Anomaly</li>
					</mods>
					<match Class="PatchOperationConditional">
						<xpath>/Defs/HediffDef[defName="DeacidifierMembrane"]/stages/li/statFactors</xpath>
						<nomatch Class="PatchOperationAdd">
							<xpath>/Defs/HediffDef[defName="DeacidifierMembrane"]/stages/li</xpath>
							<value>
								<statFactors>
									<Hauts_AcidDamageFactor>0</Hauts_AcidDamageFactor>
								</statFactors>
							</value>
						</nomatch>
						<match Class="PatchOperationAdd">
							<xpath>/Defs/HediffDef[defName="DeacidifierMembrane"]/stages/li/statFactors</xpath>
							<value>
								<Hauts_AcidDamageFactor>0</Hauts_AcidDamageFactor>
							</value>
						</match>
					</match>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Vanilla Quests Expanded - Cryptoforge</li>
					</mods>
					<match Class="PatchOperationConditional">
						<xpath>/Defs/HediffDef[defName="LTS_JotunnskinGland"]/stages/li/statFactors</xpath>
						<nomatch Class="PatchOperationAdd">
							<xpath>/Defs/HediffDef[defName="LTS_JotunnskinGland"]/stages/li</xpath>
							<value>
								<statFactors>
									<Hauts_ColdDamageFactor>0</Hauts_ColdDamageFactor>
								</statFactors>
							</value>
						</nomatch>
						<match Class="PatchOperationAdd">
							<xpath>/Defs/HediffDef[defName="LTS_JotunnskinGland"]/stages/li/statFactors</xpath>
							<value>
								<Hauts_ColdDamageFactor>0</Hauts_ColdDamageFactor>
							</value>
						</match>
					</match>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>