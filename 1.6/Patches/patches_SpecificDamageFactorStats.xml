<?xml version="1.0" encoding="utf-8" ?>
<Patch><!--Make the following damage types affected by specific "incoming x damage factor" stats
	starting with vanilla-->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="AcidBurn" or defName="VEF_SecondaryAcidBurn"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats" Inherit="False"><factorStats><li><key>Hauts_AcidDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="Frostbite"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_ColdDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="EMP"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_ElectricalDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="Bomb" or defName="BombSuper" or defName="Thump"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_ExplosiveDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="Burn" or defName="VEF_PermanentBurn"]</xpath><!--Flame has to be handled via hardcoding; xpath occurs before inheritance, and AcidBurn and ElectricalBurn inherit from Flame, so they'd get any xpath-added SDFS that Flame got.-->
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_HeatDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/DamageDef[defName="AcidBurn"]/modExtensions</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/DamageDef[defName="AcidBurn"]</xpath>
			<value>
				<modExtensions>
					<li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_AcidDamageFactor</key><value>1</value></li></factorStats></li>
				</modExtensions>
			</value>
		</nomatch>
		<match Class="PatchOperationAdd">
			<xpath>/Defs/DamageDef[defName="AcidBurn"]/modExtensions</xpath>
			<value>
				<li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_AcidDamageFactor</key><value>1</value></li></factorStats></li>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="Vaporize"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_HeatDamageFactor</key><value>0.99</value></li></factorStats></li></value><!--you can be MOSTLY immune to vaporize. but not fully. This isn't diegetically coherent, but since Vaporize is predominantly used by "fu, take ALL the damage" attacks, I felt it important that it still do at least a teensy fraction of its normal amount to folks w 0% incoming heat dmg factor-->
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>/Defs/DamageDef[defName="Beam"]</xpath>
		<value><li Class="HautsFramework.SpecificDamageFactorStats"><factorStats><li><key>Hauts_RadiationDamageFactor</key><value>1</value></li></factorStats></li></value>
	</Operation>
	
